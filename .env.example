# Morocco Healthcare Optimization — Environment Variable Template
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is in .gitignore.
#
# The application runs fully without any API keys (local fallback mode).
# Set ANTHROPIC_API_KEY only to enable LLM-powered triage responses.

# ── LLM API — Phase 5 Triage Bot ─────────────────────────────────────────────
# Optional. Without this key the triage engine uses local keyword fallback.
# Get a key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OSRM routing — Phase 2 road-network distances (optional) ─────────────────
# Leave blank to use straight-line KD-tree fallback (default).
OSRM_SERVER_URL=http://router.project-osrm.org

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
